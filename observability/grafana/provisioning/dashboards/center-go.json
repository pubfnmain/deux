      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "GOMAXPROCS (go.processor.limit) and GOGC (go.config.gogc).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "GOGC" },
